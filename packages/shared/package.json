{
  "name": "@crypto-edge/shared",
  "version": "0.1.0",
  "private": true,
  "scripts": {"build": "tsc -p tsconfig.json", "lint": "tsc -p tsconfig.json --noEmit"},
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  }
}
