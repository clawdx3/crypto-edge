{
  "name": "crypto-edge-v1",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter @crypto-edge/api --filter @crypto-edge/web dev",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "pnpm --filter @crypto-edge/api prisma:generate"
  },
  "devDependencies": {
    "@eslint/js": "9.25.1",
    "@types/node": "22",
    "eslint": "9.25.1",
    "eslint-config-prettier": "10.1.2",
    "eslint-plugin-vue": "10.0.0",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.30.1",
    "vue-eslint-parser": "10.1.3"
  }
}
