generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Assets
model Asset {
  id             String   @id @default(cuid())
  symbol         String
  name           String
  chain          String   @default("ethereum")
  contractAddress String?
  category       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  catalysts      Catalyst[]
  positions      Position[]
  walletEvents   WalletEvent[]

  @@unique([symbol, chain])
}

// Sources
model Source {
  id             String   @id @default(cuid())
  name           String   @unique
  kind           String
  baseUrl        String?
  isEnabled      Boolean  @default(true)
  rateLimitPerMin Int     @default(30)
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  syncRuns       SourceSyncRun[]
}

// Source Sync Runs
model SourceSyncRun {
  id             String   @id @default(cuid())
  sourceId       String
  source         Source   @relation(fields: [sourceId], references: [id])
  status         String
  recordsProcessed Int     @default(0)
  recordsFailed   Int     @default(0)
  errorMessage   String?
  runAt          DateTime @default(now())
  durationMs     Int?

  @@index([sourceId])
  @@index([runAt])
}

// Market Regime Snapshots
model MarketRegimeSnapshot {
  id                    String   @id @default(cuid())
  capturedAt             DateTime
  btcTrendScore          Float
  ethTrendScore          Float
  stablecoinFlowScore    Float
  tvlScore               Float
  fundingScore           Float
  openInterestScore      Float
  volatilityScore        Float
  totalScore             Float
  label                 String
  notes                 String?
  createdAt             DateTime @default(now())

  @@index([capturedAt])
  @@index([totalScore])
}

// Catalysts
model Catalyst {
  id              String   @id @default(cuid())
  assetId         String?
  asset           Asset?   @relation(fields: [assetId], references: [id])
  type            String
  title           String
  description     String?
  sourceUrl       String?
  sourceName      String?
  detectedAt      DateTime @default(now())
  effectiveAt     DateTime?
  status          String   @default("upcoming")
  impactScore     Float    @default(0)
  confidenceScore Float    @default(0)
  urgencyScore    Float    @default(0)
  rankScore       Float    @default(0)
  isManual        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, rankScore])
  @@index([effectiveAt])
  @@index([type])
}

// Wallets
model Wallet {
  id              String   @id @default(cuid())
  address         String   @unique
  label           String?
  chain           String   @default("ethereum")
  category        String
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  events          WalletEvent[]
  scores          WalletScore[]

  @@index([chain, isActive])
}

// Wallet Scores
model WalletScore {
  id                  String   @id @default(cuid())
  walletId            String
  wallet              Wallet   @relation(fields: [walletId], references: [id])
  calculatedAt        DateTime @default(now())
  winRateScore        Float    @default(0)
  timingScore         Float    @default(0)
  convictionScore     Float    @default(0)
  specializationScore Float    @default(0)
  signalQualityScore  Float    @default(0)
  totalScore          Float    @default(0)
  methodVersion       String   @default("v1")
  createdAt           DateTime @default(now())

  @@index([walletId, calculatedAt])
}

// Wallet Events
model WalletEvent {
  id              String   @id @default(cuid())
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id])
  assetId         String?
  asset           Asset?   @relation(fields: [assetId], references: [id])
  txHash          String?
  eventType       String
  amount          String?
  usdValue        Float?
  blockTimestamp  DateTime?
  summary         String?
  rawDataJson     String?
  createdAt       DateTime @default(now())

  @@index([walletId, blockTimestamp])
  @@index([assetId])
}

// Positions
model Position {
  id                  String   @id @default(cuid())
  assetId             String?
  asset               Asset?   @relation(fields: [assetId], references: [id])
  status              String   @default("open")
  thesis              String?
  entryReason         String?
  invalidation        String?
  catalystWindowStart DateTime?
  catalystWindowEnd  DateTime?
  maxSizePct          Float?
  entryPrice          Float?
  currentPrice        Float?
  currentConviction   String?
  reviewFrequencyDays Int      @default(7)
  lastReviewedAt      DateTime?
  nextReviewAt        DateTime?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  riskSnapshots        PositionRiskSnapshot[]

  @@index([status])
  @@index([nextReviewAt])
}

// Position Risk Snapshots
model PositionRiskSnapshot {
  id                    String   @id @default(cuid())
  positionId            String
  position              Position @relation(fields: [positionId], references: [id])
  capturedAt            DateTime @default(now())
  concentrationScore    Float    @default(0)
  correlationScore      Float    @default(0)
  invalidationRiskScore Float    @default(0)
  eventRiskScore        Float    @default(0)
  totalRiskScore        Float    @default(0)
  summary               String?
  createdAt             DateTime @default(now())

  @@index([positionId, capturedAt])
}

// Alerts
model Alert {
  id            String   @id @default(cuid())
  type          String
  severity      String   @default("info")
  title         String
  body          String?
  entityType    String?
  entityId      String?
  dedupeKey     String?
  status        String   @default("pending")
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([status, type])
  @@index([dedupeKey])
  @@index([entityType, entityId])
}

// Tags
model Tag {
  id         String   @id @default(cuid())
  name       String   @unique
  color      String?
  createdAt  DateTime @default(now())
}

// Gem Hunt Config
model GemHuntConfig {
  id                  String   @id @default(cuid())
  name                String
  minMarketCapUsd     Float    @default(1000)
  maxMarketCapUsd     Float    @default(5000000)
  minLiquidityUsd     Float    @default(5000)
  minVolume24h        Float    @default(10000)
  minHolders          Int      @default(10)
  excludeDexes        String[]
  chain               String   @default("solana")
  notificationEnabled Boolean @default(true)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Social Signal — tracks what social media is buzzing about
model SocialSignal {
  id             String    @id @default(cuid())
  keyword        String    // e.g., "AI+meme", "Trump coin", "dogecoin"
  platform       String    // twitter | reddit | telegram
  postCount      Int       @default(0)
  sentiment      Float     @default(0)  // -1 to 1
  reach          BigInt    @default(0)  // total impressions
  trending       Boolean   @default(false)
  avgEngagement  Float     @default(0)
  samplePosts    Json?     // [{text, likes, rt, url}]
  discoveredAt   DateTime  @default(now())
  lastScrapedAt  DateTime  @updatedAt

  @@index([keyword, platform])
  @@index([trending, discoveredAt])
}

// Token Research Report — full DD report
model TokenResearchReport {
  id              String   @id @default(cuid())
  tokenAddress    String
  chain           String
  tokenName       String?
  signalSource    String?  // what social triggered this
  signalText      String?  // the tweet/post that triggered

  // Contract Safety
  mintAuthority   Boolean?
  freezeAuthority Boolean?
  lpBurningStatus String?  // "burned" | "locked" | "unlocked" | "unknown"
  lpAmount        String?
  lpLockDuration  String?
  renounced       Boolean?
  isHoneypot      Boolean?
  isProxy         Boolean?
  proxyAddress    String?
  rugScore        Int?     @default(0)  // 0-100, higher = safer

  // Social Presence
  twitterHandle   String?
  twitterFollowers Int?
  twitterBio      String?
  redditSubreddit String?
  redditMembers   Int?
  telegramGroup   String?
  telegramMembers Int?
  website         String?

  // Team
  teamDoxxed      Boolean @default(false)
  teamNames       Json?   // [{name, role, link}]
  teamPrevTokens  Json?   // [{token, rugDate, url}]

  // Overall thesis
  thesis          String?  // "BUY" | "HOLD" | "AVOID"
  thesisStrength  Int?    // 0-100 how strong the thesis is
  thesisReasoning String? // multi-line reasoning
  riskLevel       String? // "LOW" | "MEDIUM" | "HIGH" | "EXTREME"

  // On-chain from DexScreener
  marketCap       String?
  liquidity       String?
  volume24h       String?
  price           String?
  priceChange24h  String?
  pairAddress     String?
  dexId           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tokenAddress, chain])
}

// Trending Theme — detected trend before specific tokens
model TrendingTheme {
  id          String   @id @default(cuid())
  theme       String   // e.g., "AI agents", "political meme coins", "DePIN"
  description String?
  keywords    Json     // ["ai16z", "AI agent", "autonomous"]
  platforms   Json     // {twitter: 150, reddit: 80, telegram: 40}
  sentiment   Float    @default(0)
  momentum    String   // "rising" | "peak" | "fading"
  catalyst    String?  // "Elon tweet", "news article", "protocol launch"
  detectedAt  DateTime @default(now())
  tokensFound Json?    // [{address, name, chain}]

  @@index([momentum, detectedAt])
}

// Discovered Gems
model DiscoveredGem {
  id                    String   @id @default(cuid())
  baseTokenAddress      String   @unique
  quoteTokenAddress     String
  dexId                 String
  chain                 String
  name                  String
  symbol                String
  priceUsd              Float?
  marketCapUsd          Float?
  fdvUsd                Float?
  liquidityUsd          Float?
  volume24h             Float?
  priceChange24h        Float?
  holderCount           Int?
  launchTime            DateTime?
  telegramMemberCount   Int?
  twitterFollowers      Int?
  gemScore              Float    @default(0)
  signalType            String   @default("watch")
  sourcesDetected       String[]
  notes                 String?
  status                String   @default("discovered")
  triggeredAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, gemScore])
  @@index([chain, status])
  @@index([createdAt])
}

// Whale Move — tracks smart money movements
model WhaleMove {
  id            String   @id @default(cuid())
  walletAddress String
  walletName    String
  chain         String
  tokenAddress  String?
  tokenSymbol   String?
  type          String   // "buy" | "sell" | "transfer"
  amountUsd     Float?
  txHash        String?
  detectedAt    DateTime @default(now())

  @@index([walletAddress, detectedAt])
  @@index([tokenAddress, detectedAt])
}

// CoinGecko Gem — trending coins with low DEX market cap (pre-pump gems)
model CoinGeckoGem {
  id              String   @id @default(cuid())
  coingeckoId     String   @unique
  symbol          String
  name            String
  marketCapRank   Int?
  marketCap       Float?
  dexPairAddress  String?
  dexPairChain    String?
  dexMarketCap    Float?
  upsidePotential Float?   // ratio: dex MC / coingecko MC
  signalStrength  Int?     // 0-100
  detectedAt      DateTime @default(now())

  @@index([upsidePotential])
}

// GeckoTerminal Pool — fresh liquidity events
model GeckoTerminalPool {
  id              String   @id @default(cuid())
  poolAddress     String   @unique
  network         String
  token0Symbol    String?
  token1Symbol    String?
  token0Address   String?
  token1Address   String?
  volume24h       Float?
  liquidity       Float?
  price           Float?
  isNew           Boolean  @default(false)
  detectedAt      DateTime @default(now())

  @@index([network, detectedAt])
  @@index([volume24h])
}
