# Database
POSTGRES_DB=crypto_edge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=***
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:***@localhost:5432/crypto_edge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=***
# API
API_PORT=3001

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_t...here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# CoinGecko API (free tier: 10-30 calls/min, pro: higher)
# Get at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=your_c...here

# Etherscan API (free tier: 5 calls/sec)
# Get at: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_e...here

# Web/Frontend
WEB_PORT=3000
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Node Environment
NODE_ENV=development

# Gem Hunt
GEM_HUNT_ENABLED=true
GEM_HUNT_CHAIN=solana

# Python gem hunt scraper (twscrape + PRAW)
GEM_HUNT_SCRAPER_URL=http://localhost:3002
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=***
TWITTER_EMAIL=your_twitter_email

# Reddit PRAW (free, rate limited)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_r...cret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_r...ord

# Twitter API (for SocialSignalScanner + TrendRadar) - DEPRECATED, use Python scraper instead
# Using twitter-api-v2 package — get credentials at https://developer.twitter.com/
# Option 1: Bearer Token (app-only, sufficient for search)
# TWITTER_BEARER_TOKEN=***
# Option 2: Full user context credentials
# TWITTER_API_KEY=***
# TWITTER_API_SECRET=***
# TWITTER_ACCESS_TOKEN=***
# TWITTER_ACCESS_SECRET=***

# ─── New Gem Hunt Data Sources ───────────────────────────────────────────────

# Whale Tracker — comma-separated list of name:address:chain entries
WHALE_WALLETS=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045:Vitalik.ethereum,7EqPAdgdrNywLr2MF9J3xbfbJ9eR3z9U8K7qTwZMqYhx:SolanaTrader.solana

# CoinGecko (free tier: 10-30 req/min, no key needed for trending/search)
COINGECKO_ENABLED=true

# GeckoTerminal (free, no key) — API docs: https://api.geckoterminal.com/
GECKOTERMINAL_ENABLED=true

# DEXTools — NOT FREE, do not enable
# DEXTOOLS_ENABLED=false
